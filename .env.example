# Database
# Local: postgresql://postgres:password@localhost:5432/studyos
DATABASE_URL=postgresql://postgres:password@localhost:5432/studyos

# Redis
REDIS_URL=redis://localhost:6379

# Supabase Auth
# Get these from your Supabase Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Cloudflare R2
# Get these from your Cloudflare Dashboard > R2 > Manage R2 API Tokens
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=your-bucket-name
R2_ACCOUNT_ID=your-account-id
R2_PUBLIC_DOMAIN=https://your-public-domain.com
